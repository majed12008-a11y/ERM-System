# ─── Server ───
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# ─── Database ───
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ethics_db
DB_USER=ethics_app
# Required in production. Change to your secure DB password.
DB_PASSWORD=change-this-to-your-db-password

# ─── Authentication ───
# Required. Minimum 32 chars for HS256.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change-this-to-a-random-64-char-string

# ─── CORS (production only, comma-separated) ───
CORS_ORIGIN=http://localhost:5173

# ─── Data Encryption (for national_id, passport_number, etc.) ───
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
DB_ENCRYPTION_KEY=

# ─── Migration (node-pg-migrate CLI only) ───
DATABASE_URL=postgres://ethics_migration:MIGRATION_PASSWORD@localhost:5432/ethics_db
